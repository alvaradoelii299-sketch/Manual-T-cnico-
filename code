<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Manual BlueSeer</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
        font-family: 'Poppins', sans-serif;
        display: flex;
        background: linear-gradient(135deg, #fdf2f8, #e0f2fe);
        color: #1e293b;
    }

    .sidebar {
        width: 240px;
        height: 100vh;
        background: linear-gradient(180deg, #ec4899, #8b5cf6, #06b6d4);
        padding: 20px;
        position: fixed;
        color: white;
        box-shadow: 5px 0 25px rgba(0,0,0,0.1);
    }

    .sidebar h2 {
        text-align: center;
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        margin-bottom: 20px;
    }

    .sidebar a {
        display: block;
        padding: 10px;
        margin: 6px 0;
        text-decoration: none;
        color: white;
        border-radius: 10px;
        transition: 0.3s;
    }

    .sidebar a:hover {
        background: rgba(255,255,255,0.3);
        transform: translateX(6px);
    }

    .contenido {
        margin-left: 260px;
        padding: 30px;
        width: 100%;
    }

    .titulo {
        font-family: 'Playfair Display', serif;
        font-size: 38px;
        margin-bottom: 30px;
        color: #7c3aed;
    }

    .card {
        display: flex;
        align-items: center;
        gap: 25px;
        padding: 20px;
        margin-bottom: 25px;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

    .card:hover {
        transform: translateY(-6px) scale(1.01);
    }

    .texto {
        flex: 1;
    }

    .texto h2 {
        margin: 0;
        font-size: 20px;
        color: #334155;
    }

    .texto p {
        font-size: 14px;
        color: #475569;
    }

    img {
        width: 360px;
        border-radius: 14px;
        border: 2px solid rgba(0,0,0,0.08);
    }

    .c1 { background: #ffe4e6; }
    .c2 { background: #dcfce7; }
    .c3 { background: #fef9c3; }
    .c4 { background: #e0e7ff; }
    .c5 { background: #fae8ff; }
    .c6 { background: #cffafe; }
    .c7 { background: #fce7f3; }
    .c8 { background: #ecfccb; }
    .c9 { background: #f1f5f9; }

</style>

</head>
<body>

<div class="sidebar">
    <h2>BlueSeer</h2>
    <a href="#p1">Plataforma</a>
    <a href="#p2">Descarga</a>
    <a href="#p3">Ejecutable</a>
    <a href="#p4">Directorio</a>
    <a href="#p5">Idioma</a>
    <a href="#p6">Parámetros</a>
    <a href="#p7">Acceso</a>
    <a href="#p8">Instalación</a>
    <a href="#p9">Final</a>
</div>

<div class="contenido">

